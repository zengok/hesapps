{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Web (Chrome)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port", "8080"],
      "port": 8080
    },
    {
      "name": "Flutter Web Server (headless)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "8080", "--web-hostname", "localhost"],
      "port": 8080
    },
    {
      "name": "Flutter Windows Desktop",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "windows"],
      "port": 0
    },
    {
      "name": "Flutter Android",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "android"],
      "port": 0
    }
  ]
}
